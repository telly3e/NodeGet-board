VITE_BACKEND_WS=wss://114514.local:8080
VITE_BACKEND_TOKEN=demo_token

# Private panel mode for Cloudflare Pages.
# The frontend connects to /rpc with a placeholder token. The Pages Function
# replaces it with the NODEGET_TOKEN secret before proxying to NODEGET_BACKEND_WS.
VITE_PRIVATE_PANEL=false
VITE_PRIVATE_BACKEND_NAME="My Server"
# Real controller WebSocket used by generated agent install commands.
VITE_PRIVATE_AGENT_WS=wss://nodeget.example.com/nodeget/rpc
# Browser dashboard WebSocket proxy. Leave empty to use same-origin /rpc.
VITE_PRIVATE_PROXY_WS=
VITE_PRIVATE_TOKEN_PLACEHOLDER=__NODEGET_PRIVATE_TOKEN__

# Cloudflare Pages runtime secrets for private panel mode:
# NODEGET_BACKEND_WS=wss://nodeget.example.com/nodeget/rpc
# NODEGET_TOKEN=your_nodeget_token
# PRIVATE_PANEL_ALLOWED_EMAILS=you@example.com
# PRIVATE_PANEL_SESSION_SECRET=optional_random_session_signing_secret

# Initial default for Settings > General > RPC 调试面板 data recording.
# Accepted values: true or false.
# User changes in the settings page are stored in localStorage and override this initial default.
VITE_RPC_DEBUG_PANEL_ENABLED=false
